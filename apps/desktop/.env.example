# Frontend API keys must use the VITE_ prefix.
VITE_GIPHY_API_KEY=your_giphy_api_key

# Electron main-process analytics
POSTHOG_ENABLED=false
POSTHOG_API_KEY=your_posthog_project_api_key
POSTHOG_HOST=https://us.i.posthog.com

# Desktop updater configuration
# Override the release channel for internal builds if needed.
# NUCLEUS_UPDATE_CHANNEL=beta
#
# Optional raw Authorization header sent with update checks/downloads.
# Useful later if you move Keygen distribution from OPEN to licensed access.
# NUCLEUS_UPDATE_AUTH_HEADER=License your_keygen_license_token

# The desktop app reads .env/.env.local from:
# - apps/desktop during development
# - the packaged app directory or userData directory in installed builds
